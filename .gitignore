# contracts/.gitignore
#
# ALLOWLIST approach: ignore everything, then whitelist safe paths.
# This prevents accidental commits of sensitive scripts, keys, or temp files.
# To add a new file to the repo, explicitly add its path below.

# Ignore everything by default
*

# === Allowed: repo config ===
!.gitignore
!.gitmodules
!LICENSE
!README.md
!foundry.toml
!foundry.lock
!remappings.txt

# === Allowed: source code ===
!src/
!src/**
!script/
!script/**
!test/
!test/**
!lib/
!lib/**
